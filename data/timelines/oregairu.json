      "urgency": "low"
    },
    "beats": [
      {
        "id": "accept",
        "label": "答应帮忙",
        "prompt": "第二天放学后，由比滨结衣正式来到侍奉部。她扭捏着说明来意——想给某个重要的人做曲奇，但自己完全不会。雪乃已经开始从基础教起。现在正是加入帮忙的好时机。",
        "outcomes": [
          { "pick": "一起指导做曲奇", "effects": { "affection": { "由比滨结衣": 10, "雪之下雪乃": 5 }, "flags": { "cookie_helped": true } }, "next_beat": "baking" },
          { "pick": "在旁边看着", "effects": { "affection": { "由比滨结衣": 3, "雪之下雪乃": 3 }, "flags": { "cookie_watched": true } }, "next_beat": "baking" }
        ]
      },
      {
        "id": "baking",
        "label": "曲奇烤好了",
        "prompt": "经过几天的练习，结衣的曲奇终于像样了。她把成品分给侍奉部的每个人品尝。味道出乎意料地好。结衣红着脸道谢。这个委托算是圆满完成了。",
        "effects": { "flags": { "cookie_complete": true } }
      },
      {
        "id": "ignore",
        "label": "拒绝/无视",
        "prompt": "雪乃等了几秒，见你没有回应，便转回身去。「算了。」她的声音里没有失望，但你注意到她翻书的手指微微用力。之后几天，她独自处理了那个一年级女生的事。",
        "effects": { "affection": { "雪之下雪乃": -5 }, "flags": { "cookie_ignored": true } },
        "expires_quest": true
      }
    ],
    "on_expire": {
      "narrative": "几周后你偶然想起侍奉部门口那个一年级女生的身影。但已经很久没见到她了。大概雪乃独自把事情处理好了。",
      "effects": { "flags": { "cookie_missed": true } }
    }
  },
  {
    "id": "zaimokuza_novel",
    "title": "材木座的轻小说委托",
