      "urgency": "medium"
    },
    "beats": [
      {
        "id": "accept",
        "label": "帮忙审稿",
        "prompt": "材木座义辉，2年C班，自称「剑豪将军」。他写了一份轻小说原稿，但被编辑部批评「缺乏女性角色真实感」。雪乃已经开始用红笔批注。原稿的剧情走向和角色塑造都需要你的意见。",
        "outcomes": [
          { "pick": "认真给出修改意见", "effects": { "affection": { "雪之下雪乃": 5 }, "flags": { "novel_helped": true } }, "next_beat": "feedback" },
          { "pick": "敷衍了事", "effects": { "affection": { "材木座义辉": -3 }, "flags": { "novel_weak": true } }, "next_beat": "feedback" }
        ]
      },
      {
        "id": "feedback",
        "label": "反馈结果",
        "prompt": "几天后，材木座拿着修改稿回来了。编辑的反馈好了不少——至少女性角色不再全是「巨乳美少女剑士」了。材木座感动得差点当场跪下。",
        "effects": { "flags": { "novel_complete": true } }
      },
      {
        "id": "ignore",
        "label": "拒绝",
        "prompt": "雪乃看了你一眼，接过了稿纸。「我自己来就行。」你注意到材木座的表情有些尴尬。之后几天侍奉部里多了一堆稿纸，而材木座每次见到你都会尴尬地别过脸去。",
        "effects": { "flags": { "novel_ignored": true } },
        "expires_quest": true
      }
    ],
    "on_expire": {
      "narrative": "材木座偶尔还会来侍奉部，但他已经不抱希望了。那份轻小说大概永远停留在「全是巨乳美少女剑士」的初稿状态了。",
      "effects": { "flags": { "novel_missed": true } }
    }
  },
