  "beats": [
    {
      "id": "moonlight_talk",
      "label": "长椅上的倾听",
      "prompt": "雪乃双手环抱在膝前，声音有些低沉。她罕见地提起了小学时被孤立、被拿走室内鞋的往事，流露出最真实而脆弱的一面。{{player.surname}}决定：",
      "outcomes": [
        {
          "pick": "轻轻坐过去抱住她，用实际的温度安慰她",
          "effects": {
