  "hook": {
    "source_npc": "雪之下雪乃",
    "hook_text": "随着高三学长们的毕业季临近，雪之下雪乃为了向母亲证明自己，主动接下了筹办‘毕业舞会’(Prom)的委托。然而，舞会计划遭到了雪乃母亲以及家长会的极力反对。雪乃在特别大楼的社办里，独自对着企划书思索。她需要一份坚定的力量支持。",
    "urgency": "medium"
  },
  "beats": [
    {
      "id": "prom_dilemma",
      "label": "舞会风波",
      "prompt": "雪乃坚持一个人完成毕业舞会的筹办工作，甚至为此在校外奔走，身体已有些吃不消。八幡为了在暗中帮她解决来自家长会的阻力，计划自己做一份看似更乱的‘备用舞会企划’作为诱饵来促成雪乃企划的通过。由比滨在一旁协助他。但如果{{player.surname}}站出来，或许能直接正面解决家长会的刁难。",
      "outcomes": [
        {
          "pick": "让八幡去协助运作备用舞会企划，并让雪乃依靠八幡的帮助来解决危机（走原著线）",
          "effects": {
            "flags": { "hachiman_prom_led": true }
          },
          "next_beat": "hachiman_bridge"
        },
        {
          "pick": "自己正面出面游说学校与家长会，用更完美的方案彻底打消反对意见，并正式向雪乃告白（走玩家线）",
          "effects": {
            "flags": { "player_prom_led": true }
          },
          "next_beat": "player_bridge",
          "auto_if": {
            "romance": { "雪之下雪乃": "恋人" },
            "flags": { "player_park_led": true }
          }
        }
      ]
    },
    {
      "id": "hachiman_bridge",
      "label": "桥头上的诉求",
