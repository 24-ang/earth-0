  "personality_brief": "讲日本史能讲到热泪盈眶的中年男人。对战国时代有近乎狂热的爱，讲到本能寺之变总会哽咽。学生评价「听大森的课像在看大河剧+落语混合体」。在教员室里是个老好人，从不参与派系斗争。担任2年A班班主任。",
  "personality_stages": {
    "12": "喜欢读历史漫画的安静少年，对三国志和战国武将如数家珍。",
    "15": "加入了历史研究同好会，开始读正史而非演义。",
    "18": "考取千叶大学教育学部，专攻日本近世史。",
    "45": "教了二十年书的老教师。对每个学生的名字和性格都记得。对教育热情不减但体力开始跟不上了。"
  },
  "speech_style": "热情洋溢，带点说书人的腔调。对历史人物有明确的道德立场——「信长是天才但不是好人，光秀是叛徒但我理解他」。上课时偶尔会突然切换成战国武将的口气。",
  "likes": [
    "战国史",
    "大河剧",
    "落语",
    "温泉",
    "日本酒"
  ],
  "dislikes": [
    "历史修正主义",
    "派系斗争",
    "智能手机（不太会用）"
  ],
  "public_facts": [
    {
      "text": "总武高的日本史兼世界史教师，2年A班班主任。",
      "level": "common"
    },
    {
      "text": "上课旁征博引、妙趣横生，是学生投票'最想再听一节课'的教师第一名。",
      "level": "common"
    },
    {
      "text": "据说年轻时被邀请去NHK做历史节目的顾问，但拒绝了——因为'不想离开讲台'。",
      "level": "common"
    }
  ],
  "private_facts": [
    {
      "text": "妻子十年前病故，独自把女儿养大。女儿现在在东京上大学，每周回来一次。",
      "level": "close"
    },
    {
      "text": "办公桌最下面的抽屉里锁着一本未完成的战国小说手稿——写了二十年还没写完。",
      "level": "close"
    }
