  "beats": [
    {
      "id": "device_activation",
      "label": "装置的使用判定",
      "prompt": "雪乃正坐着翻阅手中的参考书。手中握着的黑科技改写装置散发着微光，只要按下按钮，就可以永久地改变她的某些核心概念。{{player.surname}}决定：",
      "outcomes": [
        {
          "pick": "对雪之下雪乃发动装置，将「性侍奉」常识写入她的认知中",
          "effects": {
            "flags": {
              "device_triggered": true
            }
          },
          "next_beat": "device_success"
        },
        {
          "pick": "收起装置拒绝发动，只是走过去跟她普通地搭话",
          "effects": {
            "flags": {
              "route_brainwash_declined": true
            }
          },
          "next_beat": null
        }
      ]
    },
    {
      "id": "device_success",
      "label": "概念的重塑",
      "prompt": "装置发出了一阵微不可查的脉冲。雪乃翻书的手微微停滞了一下，随即有些疑惑地揉了揉眉心，很快便恢复了常态。改写成功：现在她的常识中，「满足你的性需求」已经成为了她作为侍奉部部长理所应当承担的重大职责。她依然是那个冷酷完美、毒舌的雪乃，但脑海中已经多了一条逻辑。{{player.surname}}决定：",
      "outcomes": [
        {
          "pick": "不动声色地收回装置离开，等待未来的改写显效",
