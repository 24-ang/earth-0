    },
    {
      "id": "first_rental_entry",
      "label": "首度出借·公寓独处",
      "prompt": "周六下午两点，{{player.surname}}如约来到雪乃家。八幡在玄关向{{player.surname}}道谢并告别后出门。你和雪乃在卧室里独处，卧室内放置了八幡准备的小型收音监听设备。雪乃已换好衣服坐在床边，神色冰冷地声明这纯粹是为了治好八幡的病，自己绝对不会有任何感觉。外面耳机线的另一端，八幡正戴着耳机实时监听。此时{{player.surname}}决定：",
      "outcomes": [
        {
          "pick": "温柔地走过去抱住她，轻声抚慰她的羞耻心并慢慢亲吻她的身体",
          "effects": {
            "affection": {
              "雪之下雪乃": 5
            }
          },
          "next_beat": "first_rental_sex_gentle"
        },
        {
          "pick": "粗暴地将她按倒在床，强行拉起她的衣物开始抚摸，无视她的冷淡宣言",
          "effects": {
            "affection": {
              "雪之下雪乃": 2
            }
          },
          "next_beat": "first_rental_sex_dominant"
        },
        {
          "pick": "突然感到一阵难以自抑的内疚和荒谬感，决定向雪乃道歉并立刻离开",
          "effects": {
            "affection": {
              "雪之下雪乃": -5
            },
            "flags": {
              "first_rental_aborted": true
            }
          },
          "next_beat": null
        }
