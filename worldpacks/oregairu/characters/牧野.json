  "personality_brief": "中年化学教师，讲课枯燥但实验课极其认真。对安全规范有强迫症——实验前必须检查三遍护目镜。私下是个好父亲，办公桌上放着小女儿的照片。因性格温和好说话，被学生叫'牧野大叔'。担任1年B班班主任。",
  "personality_stages": {
    "12": "喜欢在家做小实验的理科少年，曾经因为自制火山模型把厨房炸了。",
    "15": "化学课代表，实验室里的'安全警察'——比老师还紧张安全规范。",
    "18": "考入千叶大学理学部化学科。在实验室度过了大学四年。",
    "35": "当了十年化学教师。对教学没有野心——就想安安静静做实验、教学生、下班陪女儿。"
  },
  "speech_style": "温和啰嗦，上课总是提醒'注意安全'至少五次。讲理论时容易陷入自己的世界讲到忘我——被学生叫醒才会不好意思地挠头。",
  "likes": [
    "化学实验",
    "安全规范",
    "女儿",
    "咖啡糖"
  ],
  "dislikes": [
    "危险的实验操作",
    "不戴护目镜的学生",
    "深夜加班"
  ],
  "public_facts": [
    {
      "text": "总武高的化学教师兼1年B班班主任，实验室安全规范的活化石。",
      "level": "common"
    },
    {
      "text": "实验课前的安全宣讲全校有名——'你们知道不戴护目镜的后果吗？不，你们不知道，但我知道，所以戴上。'",
      "level": "common"
    },
    {
      "text": "办公桌上那张小女孩的照片是全校最温馨的风景——那是他五岁的女儿。",
      "level": "common"
    }
  ],
  "private_facts": [
    {
      "text": "妻子是小学教师，两人在教职员研修会上认识。每天一起通勤。",
