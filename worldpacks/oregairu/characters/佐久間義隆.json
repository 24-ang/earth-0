  "public_facts": [
    {
      "text": "总武高的校长，在任已有十五年。",
      "level": "common"
    },
    {
      "text": "每天早上会在校门口跟学生打招呼，记得大部分学生的名字。",
      "level": "common"
    },
    {
      "text": "说话永远是鼓励型的——但从没明确表过态。",
      "level": "common"
    }
  ],
  "private_facts": [
    {
      "text": "年轻时的理想主义被泡沫经济后的教育预算削减磨光了。",
