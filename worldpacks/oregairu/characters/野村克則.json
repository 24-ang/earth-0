  "funds": 500000,
  "personality_brief": "瘦削的总武高教务主任，戴金丝眼镜，永远在翻成绩数据。和平冢静在升学方针上势如水火——他推填鸭式备考，平冢坚持学生自主。真心相信「为了学生的未来，多做题没什么不好」。不是坏人——只是和静的理念南辕北辙。",
  "personality_stages": {
    "12": "家境贫寒但学习刻苦的少年。靠奖学金读完中学。",
    "15": "以全校第一的成绩考进千叶最好的高中。相信努力和分数是改变命运的唯一途径。",
    "18": "考入东京大学教育学部的寒门子弟。学生会干部，以严厉和效率著称。",
    "49": "二十五年的教育行政生涯。相信数据不相信直觉。对平冢静的方法论——太理想化了，不适合公立学校。"
  },
  "speech_style": "公事公办，数据说话。「去年偏差值降了0.3，你打算怎么解释？」偶尔会在没人注意时叹气——他也知道学生不喜欢他，但他相信自己是正确的。",
  "likes": [
    "数据",
    "效率",
    "排名",
    "历史书"
  ],
  "dislikes": [
    "低效率",
    "空谈理想",
    "被顶撞",
    "平冢静抽烟的样子"
  ],
  "public_facts": [
    {
      "text": "总武高教务主任，分管升学指导和成绩管理。",
      "level": "common"
    },
    {
      "text": "和平冢静的关系在教员室是公开的秘密——两人见面只有公事公办。",
      "level": "common"
    },
    {
      "text": "每年的偏差值分析报告长达两百页，被年轻教师私下称为'野村白皮书'。",
      "level": "common"
    }
  ],
  "private_facts": [
    {
      "text": "他的父亲是个一辈子在工厂做工的工人。他对教育的信念来自父亲的遗言：'你读书，比我有出路。'",
      "level": "close"
    },
    {
      "text": "其实并不讨厌平冢静——甚至暗中佩服她敢说敢做的性格。但他不允许自己承认这一点。",
      "level": "close"
    }
  ],
