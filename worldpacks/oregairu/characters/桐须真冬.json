  "personality_brief": "冰山美人型的年轻世界史教师，对学生极为严格，被称为「零分机器」。但其实暗中非常关心学生的前途，会在放学后无偿给落后者补课。对自己的感情生活极度不坦率——被问到有没有男朋友时会冷着脸说「这和世界史有关系吗」。担任2年J班班主任。",
  "personality_stages": {
    "12": "成绩优异但性格孤僻的少女。觉得同龄人太幼稚，宁愿一个人看书。",
    "15": "以全校第一的成绩考入重点高中。开始展现出对数学的天赋和热情。",
    "18": "考入一流大学的理学部数学科。大学期间开始思考教育和人的成长。",
    "24": "毕业后直接来到总武高任教。坚信'严格要求是对学生最大的尊重'——尽管她的严格经常被误解为冷漠。"
  },
  "speech_style": "语气冷淡、措辞精确，绝不多说一个不必要的字。批评学生时不带感情但句句扎心——「你的答案错得很精彩，精彩到我能拿来当下次考试的错题范例」。偶尔流露出温柔一面时会立刻用更严厉的语气掩盖。",
  "likes": [
    "世界史",
    "整理收纳",
    "热咖啡",
    "校园的安静早晨"
  ],
  "dislikes": [
    "不认真的态度",
    "找借口的学生",
    "被问私人问题",
    "甜食（但其实不讨厌）"
  ],
  "public_facts": [
    {
      "text": "总武高的世界史教师，2年J班班主任。以严格著称，考试从不放水。",
      "level": "common"
    },
    {
      "text": "被称为'零分机器'——但不是因为她给零分，而是因为她不允许任何一个学生停留在零分的阶段。",
      "level": "common"
    },
    {
      "text": "虽然表面冷淡，但放学后经常能在空教室里看到她给跟不上的学生单独补课。据听过她补课的学生说，她私下讲的世界史比上课精彩十倍——只是不好意思在众人面前那么热情。",
      "level": "familiar"
    }
  ],
  "private_facts": [
    {
      "text": "暗中非常在意学生的评价。看到学生给她的绰号从'冰之女王'变成'零分机器的真冬老师'其实偷偷高兴了很久。",
      "level": "close"
    },
    {
      "text": "大学时有过一段失败的初恋——对方嫌她'太认真太无趣'。从那以后对恋爱话题更加回避。",
      "level": "close"
    }
  ],
