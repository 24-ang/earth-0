  "entries": [
    {
      "tag": "总武高偏差值排名",
      "level": "common",
      "triggers": {
        "locations": [
          "总武高"
        ],
        "topics": [
          "升学",
          "偏差值",
          "考试"
        ],
        "orgs": [
          "总武高"
        ]
      },
      "text": "总武高偏差值约68，千叶县公立校前5。偏差值低于60基本无缘。校风自由，升学实绩突出。"
    },
    {
      "tag": "总武高校规",
      "level": "common",
      "triggers": {
        "locations": [
          "总武高"
        ],
        "topics": [
          "校规",
          "纪律"
        ]
      },
      "text": "校内严禁不纯异性交往。牵手都要躲着老师。校园内不可吸烟——平冢静只能在停车场角落偷偷抽。"
    },
    {
      "tag": "总武高社团",
      "level": "common",
      "triggers": {
        "locations": [
          "总武高"
        ],
        "topics": [
          "社团",
          "部活"
        ]
      },
      "text": "总武高社团活动活跃。运动部有棒球/足球/田径/网球；文化部有美术/吹奏/文学。侍奉部是冷门小社团。"
    },
    {
      "tag": "海滨综合高不良",
      "level": "common",
      "triggers": {
        "locations": [
          "总武高"
        ],
        "topics": [
          "不良",
          "打架",
          "外校"
        ],
        "orgs": [
          "总武高"
        ]
      },
      "text": "隔壁海滨综合高是千叶偏差值最低的公立校之一，部分学生有组织犯罪关联。总武高学生放学后绕路走。"
    },
    {
      "tag": "教务内斗",
      "level": "industry",
      "triggers": {
        "roles": [
          "教师",
          "总武高教师"
        ],
        "orgs": [
          "总武高"
        ]
      },
      "text": "平冢静和教务主任在升学方针上长期不合。教务主任推填鸭式备考，平冢坚持学生自主。"
    },
    {
      "tag": "总武高班级编制",
      "level": "common",
      "triggers": {
        "locations": [
          "教学楼",
          "教室",
          "总武高"
        ],
        "topics": [
          "班级",
          "班上",
          "同学",
          "同班",
          "班会",
          "クラス"
        ]
      },
      "text": "总武高每班25-30人，全校约840名学生。1年生：A-B特進(30人)·C-I普通(27-28人)·J国際教養(25人)。2年生文理分科后：A-B文系特進·C-F文系·G-I理系·J国際教養。3年延续2年编成。特進班人数略多（备考氛围浓），国際教養班人数最少（英语门槛筛掉一半志愿）。教室座位是单人单桌、6列×5排或5列×6排——教室后方有空余空间，靠窗一排看得到中庭。"
    },
    {
      "tag": "总武高游泳部",
      "level": "common",
      "triggers": {
        "locations": [
          "游泳池",
          "プール",
          "更衣室"
        ],
        "topics": [
          "游泳",
          "水泳",
          "泳ぎ",
          "泳衣",
          "水着"
        ]
      },
      "text": "总武高游泳部每周一三五放学后训练，夏季晨练（7:00-8:00）额外开放。王牌水上諒真（2年G班·100m自由形県6位）每天第一个到。顾问藤崎穗成美出了名的严厉——迟到一分钟罚游十圈。训练结束后她会额外指导水上入水动作——这个场景在部员间有个不言明的名字：'補講タイム'。其他部员都知道这个时间不能打扰——除了还不知道规则的新人。"
    }
  ],
